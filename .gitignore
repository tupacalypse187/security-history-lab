.DS_Store
.AppleDouble
.LSOverride
._*

# --- IDEs / Editors ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- Build / Temp ---
*.tmp
*.bak
*.cache
node_modules/
".qwen/"  
